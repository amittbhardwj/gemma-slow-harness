# Provider
GEMMA_PROVIDER=ollama
GEMMA_MODEL=gemma4:12b
GEMMA_BASE_URL=http://localhost:11434

# Mac mini M4 16 GB default: safe profile
GEMMA_MEMORY_PROFILE=safe
GEMMA_NUM_CTX=4096
GEMMA_MAX_TOKENS=1024
GEMMA_CANDIDATES=3
GEMMA_DEBATE_ROUNDS=1
GEMMA_MIN_SCORE=80

# Ollama memory/KV policy. These must be set before `ollama serve` starts.
OLLAMA_FLASH_ATTENTION=1
OLLAMA_KV_CACHE_TYPE=q8_0
OLLAMA_CONTEXT_LENGTH=4096

# Active context compaction. 0 = auto-budget based on num_ctx/max_tokens.
GEMMA_CONTEXT_BUDGET_TOKENS=0

# Workspace and storage-backed cold memory
GEMMA_WORKSPACE=.
GEMMA_RAG_DB=.gemma_harness/rag.sqlite3
GEMMA_LEARNING_ENABLED=true
GEMMA_LEARNING_DB=.gemma_harness/learning.sqlite3
GEMMA_MEMORY_TOP_K=5
GEMMA_SKILL_TOP_K=3
GEMMA_AUTO_LEARN_MIN_SCORE=80

# Safety: write/shell tools are disabled by default.
GEMMA_ALLOW_WRITE=false
GEMMA_ALLOW_SHELL=false

# macOS desktop automation. Disabled by default.
# Requires System Settings → Privacy & Security → Accessibility.
GEMMA_ALLOW_MAC_CONTROL=false
# Requires System Settings → Privacy & Security → Screen Recording.
GEMMA_ALLOW_MAC_SCREENSHOT=false
